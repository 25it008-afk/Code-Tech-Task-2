<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Responsive Landing Page</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    line-height:1.6;
}

/* Navigation */

nav{
    position:fixed;
    top:0;
    width:100%;
    background:#0d47a1;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:15px 8%;
    color:#fff;
    z-index:1000;
}

nav h2{
    font-size:28px;
}

nav ul{
    display:flex;
    list-style:none;
}

nav ul li{
    margin-left:25px;
}

nav ul li a{
    text-decoration:none;
    color:#fff;
    font-size:18px;
    transition:0.3s;
}

nav ul li a:hover{
    color:#ffeb3b;
}

/* Hero */

.hero{
    height:100vh;
    background:linear-gradient(rgba(0,0,0,.6),rgba(0,0,0,.6)),
    url("https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=1600&q=80") center/cover;
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
    color:white;
    padding:20px;
}

.hero h1{
    font-size:55px;
}

.hero p{
    margin:20px 0;
    font-size:20px;
}

.btn{
    background:#ff9800;
    color:white;
    padding:14px 30px;
    text-decoration:none;
    border-radius:5px;
    font-size:18px;
}

.btn:hover{
    background:#e65100;
}

/* Features */

.features{
    padding:70px 8%;
    text-align:center;
}

.features h2{
    margin-bottom:40px;
    font-size:36px;
}

.cards{
    display:flex;
    justify-content:center;
    flex-wrap:wrap;
    gap:25px;
}

.card{
    width:300px;
    background:#fff;
    padding:25px;
    border-radius:10px;
    box-shadow:0 5px 12px rgba(0,0,0,.2);
}

.card h3{
    margin-bottom:15px;
    color:#0d47a1;
}

/* About */

.about{
    background:#f4f4f4;
    padding:70px 8%;
    text-align:center;
}

.about h2{
    margin-bottom:20px;
}

/* Contact */

.contact{
    padding:70px 8%;
    text-align:center;
}

.contact button{
    background:#0d47a1;
    color:white;
    border:none;
    padding:14px 30px;
    font-size:18px;
    border-radius:5px;
    cursor:pointer;
}

.contact button:hover{
    background:#002171;
}

/* Footer */

footer{
    background:#0d47a1;
    color:white;
    text-align:center;
    padding:20px;
}

/* Responsive */

@media(max-width:768px){

nav{
    flex-direction:column;
}

nav ul{
    margin-top:10px;
    flex-wrap:wrap;
    justify-content:center;
}

.hero h1{
    font-size:38px;
}

.hero p{
    font-size:17px;
}

}
</style>

</head>

<body>

<nav>
<h2>MyBrand</h2>

<ul>
<li><a href="#home">Home</a></li>
<li><a href="#features">Features</a></li>
<li><a href="#about">About</a></li>
<li><a href="#contact">Contact</a></li>
</ul>

</nav>

<section class="hero" id="home">

<div>

<h1>Build Your Dream Website</h1>

<p>
Create beautiful, responsive and modern websites with HTML, CSS and JavaScript.
</p>

<a href="#features" class="btn">Get Started</a>

</div>

</section>

<section class="features" id="features">

<h2>Our Features</h2>

<div class="cards">

<div class="card">
<h3>Responsive Design</h3>
<p>Works perfectly on desktops, tablets, and mobile devices.</p>
</div>

<div class="card">
<h3>Modern UI</h3>
<p>Clean and attractive user interface with smooth navigation.</p>
</div>

<div class="card">
<h3>Fast Performance</h3>
<p>Optimized layout for faster loading and better user experience.</p>
</div>

</div>

</section>

<section class="about" id="about">

<h2>About Us</h2>

<p>
We create responsive websites that help businesses and individuals establish a strong online presence. Our goal is to provide modern, fast, and user-friendly web solutions.
</p>

</section>

<section class="contact" id="contact">

<h2>Contact Us</h2>

<p>Email: info@example.com</p>
<p>Phone: +91 9876543210</p>

<br>

<button onclick="showMessage()">Contact Now</button>

</section>

<footer>

<p>© 2026 Responsive Landing Page. All Rights Reserved.</p>

</footer>

<script>

function showMessage(){
    alert("Thank you for contacting us! We will get back to you soon.");
}

// Navbar background change on scroll
window.addEventListener("scroll", function(){
    const nav=document.querySelector("nav");
    if(window.scrollY>50){
        nav.style.background="#002171";
    }else{
        nav.style.background="#0d47a1";
    }
});

</script>

</body>
</html>
